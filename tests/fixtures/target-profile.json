{
  "log": {
    "level": "debug",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/tmp/sing-box-cache.db"
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090"
    }
  },
  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "dns-direct",
        "server": "1.1.1.1"
      },
      {
        "type": "https",
        "tag": "dns-remote",
        "server": "1.1.1.1",
        "path": "/dns-query",
        "detour": "proxy"
      }
    ],
    "rules": [
      {
        "rule_set": [
          "my-custom",
          "geosite-google-deepmind",
          "geosite-linkedin",
          "geosite-instagram",
          "geosite-youtube",
          "geosite-openai"
        ],
        "action": "route",
        "server": "dns-remote"
      }
    ],
    "final": "dns-direct",
    "strategy": "prefer_ipv4",
    "cache_capacity": 4096
  },
  "inbounds": [
    {
      "type": "direct",
      "tag": "dns-in",
      "listen": "127.0.0.1",
      "listen_port": 5353
    },
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "singtun",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1420,
      "auto_route": true,
      "strict_route": false,
      "stack": "system"
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "proxy",
      "server": "example.com",
      "server_port": 443,
      "uuid": "00000000-0000-0000-0000-000000000000",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "dl.google.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "REPLACE_WITH_PUBLIC_KEY",
          "short_id": "0123456789abcdef"
        }
      },
      "multiplex": {
        "enabled": true
      }
    },
    {
      "type": "vless",
      "tag": "tls-off",
      "server": "tls-off.example.com",
      "server_port": 443,
      "uuid": "11111111-1111-1111-1111-111111111111",
      "tls": {
        "enabled": false,
        "server_name": "stale.example.com"
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "dns-direct"
    },
    "rule_set": [
      {
        "type": "local",
        "tag": "my-custom",
        "format": "source",
        "path": "/etc/sing-box/rules/proxy-list.json"
      },
      {
        "type": "remote",
        "tag": "geosite-google-deepmind",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-google-deepmind.srs",
        "download_detour": "direct",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geosite-linkedin",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-linkedin.srs",
        "download_detour": "direct",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geosite-youtube",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-youtube.srs",
        "download_detour": "direct",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geosite-instagram",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-instagram.srs",
        "download_detour": "direct",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geosite-openai",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-openai.srs",
        "download_detour": "direct",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-cn.srs",
        "update_interval": "1d"
      }
    ],
    "rules": [
      {
        "protocol": [
          "dns"
        ],
        "action": "hijack-dns"
      },
      {
        "inbound": [
          "dns-in"
        ],
        "action": "hijack-dns"
      },
      {
        "port": 53,
        "action": "hijack-dns"
      },
      {
        "sniffer": [
          "http",
          "tls",
          "quic"
        ],
        "action": "sniff"
      },
      {
        "network": [
          "udp"
        ],
        "port": 443,
        "action": "route",
        "outbound": "block"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "my-custom",
          "geosite-google-deepmind",
          "geosite-linkedin",
          "geosite-instagram",
          "geosite-youtube",
          "geosite-openai",
          "geoip-cn"
        ],
        "action": "route",
        "outbound": "proxy"
      }
    ],
    "final": "direct"
  }
}
